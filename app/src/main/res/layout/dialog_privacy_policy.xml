<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A6000000"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_inner_frame"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvMessageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="سياسة الخصوصية\nPrivacy Policy"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgMessageIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:layout_marginTop="15dp"
            android:src="@drawable/ic_settings_gear" />

        <TextView
            android:id="@+id/tvMessageBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:text="أهلاً بك في حشود المجد!\nيرجى قراءة والموافقة على سياسة الخصوصية وشروط الاستخدام للمتابعة.\n\nWelcome to Mobs of Glory!\nPlease read and accept our Privacy Policy and Terms of Service to continue."
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnReadPolicy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:background="@drawable/bg_inner_frame"
            android:text="قراءة السياسة / READ POLICY"
            android:textColor="#BDC3C7" />

        <Button
            android:id="@+id/btnAcceptPolicy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_btn_gold_border"
            android:text="موافقة / ACCEPT"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>
</FrameLayout>
