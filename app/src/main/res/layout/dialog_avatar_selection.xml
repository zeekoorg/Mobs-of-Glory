<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dialogBox"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.90"
        app:layout_constraintHeight_percent="0.85"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/bg_dialog_dark" />

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:text="المعرض الملكي للصور"
            android:textColor="#F4D03F"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"
            app:layout_constraintTop_toBottomOf="@id/tvDialogTitle"
            app:layout_constraintBottom_toTopOf="@id/btnClose">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الصورة الأساسية (مجانية)"
                    android:textColor="#BDC3C7"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_inner_frame"
                    android:padding="10dp"
                    android:layout_marginBottom="15dp">
                    
                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp">
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="40dp"
                            app:cardElevation="0dp"
                            android:layout_margin="4dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/img_default_avatar" />
                        </androidx.cardview.widget.CardView>
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_user_frame" />
                    </FrameLayout>
                    
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="القائد الأساسي" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" android:layout_marginTop="6dp"/>
                    
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnUseDefaultAvatar"
                        android:layout_width="100dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_btn_gold_border"
                        android:text="اختيار"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:padding="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:includeFontPadding="false"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#555555" android:layout_marginVertical="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الصور النادرة (شراء دائم)"
                    android:textColor="#F4D03F"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginVertical="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="10dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_inner_frame" android:layout_marginEnd="4dp" android:padding="10dp">
                        <FrameLayout android:layout_width="70dp" android:layout_height="70dp">
                            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardCornerRadius="35dp" app:cardElevation="0dp" android:layout_margin="3dp">
                                <ImageView android:id="@+id/imgAvatarKing" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/img_avatar_king"/>
                            </androidx.cardview.widget.CardView>
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_user_frame" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الملك" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnBuyAvatarKing"
                            android:layout_width="100dp"
                            android:layout_height="32dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_btn_gold_border"
                            android:text="50K ذهب"
                            android:textColor="#F4D03F"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:includeFontPadding="false"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_inner_frame" android:layout_marginStart="4dp" android:padding="10dp">
                        <FrameLayout android:layout_width="70dp" android:layout_height="70dp">
                            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardCornerRadius="35dp" app:cardElevation="0dp" android:layout_margin="3dp">
                                <ImageView android:id="@+id/imgAvatarKnight" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/img_avatar_knight"/>
                            </androidx.cardview.widget.CardView>
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_user_frame" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الفارس" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnBuyAvatarKnight"
                            android:layout_width="100dp"
                            android:layout_height="32dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_btn_gold_border"
                            android:text="50K ذهب"
                            android:textColor="#F4D03F"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:includeFontPadding="false"
                            android:stateListAnimator="@null" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="10dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_inner_frame" android:layout_marginEnd="4dp" android:padding="10dp">
                        <FrameLayout android:layout_width="70dp" android:layout_height="70dp">
                            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardCornerRadius="35dp" app:cardElevation="0dp" android:layout_margin="3dp">
                                <ImageView android:id="@+id/imgAvatarAssassin" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/img_avatar_assassin"/>
                            </androidx.cardview.widget.CardView>
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_user_frame" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="شبح الليل" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnBuyAvatarAssassin"
                            android:layout_width="100dp"
                            android:layout_height="32dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_btn_gold_border"
                            android:text="50K ذهب"
                            android:textColor="#F4D03F"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:includeFontPadding="false"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_inner_frame" android:layout_marginStart="4dp" android:padding="10dp">
                        <FrameLayout android:layout_width="70dp" android:layout_height="70dp">
                            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardCornerRadius="35dp" app:cardElevation="0dp" android:layout_margin="3dp">
                                <ImageView android:id="@+id/imgAvatarEmperor" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/img_avatar_emperor"/>
                            </androidx.cardview.widget.CardView>
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/ic_user_frame" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الإمبراطور" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnBuyAvatarEmperor"
                            android:layout_width="100dp"
                            android:layout_height="32dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_btn_gold_border"
                            android:text="50K ذهب"
                            android:textColor="#F4D03F"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:includeFontPadding="false"
                            android:stateListAnimator="@null" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#555555" android:layout_marginVertical="10dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnChooseFromGallery"
                    android:layout_width="220dp"
                    android:layout_height="45dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_btn_gold_border"
                    android:text="🖼️ اختيار من المعرض (VIP)"
                    android:textColor="#2ECC71"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:includeFontPadding="false"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </ScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnClose"
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:layout_marginBottom="25dp"
            android:background="@drawable/bg_btn_gold_border"
            android:text="إغلاق المعرض"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:gravity="center"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:includeFontPadding="false"
            android:stateListAnimator="@null" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
