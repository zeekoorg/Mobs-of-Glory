<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr"
    android:background="#121212">

    <ImageView
        android:id="@+id/imgArenaBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_arena_battlefield" />
        
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4D000000"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topHudContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="H,5.4:1"
        android:layout_marginHorizontal="2dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/bg_top_hud_blank" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="10"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3">
                
                <FrameLayout
                    android:id="@+id/layoutAvatarClick"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="100dp"
                        app:cardElevation="0dp"
                        android:layout_margin="3dp">
                        <ImageView
                            android:id="@+id/imgMainPlayerAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_default_avatar" />
                    </androidx.cardview.widget.CardView>
                    
                    <ImageView 
                        android:id="@+id/imgAvatarFrame" 
                        android:layout_width="match_parent" 
                        android:layout_height="match_parent" 
                        android:src="@drawable/ic_user_frame" />
                </FrameLayout>
                
                <ProgressBar android:id="@+id/pbPlayerHP" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_marginStart="6dp" android:progress="100" android:progressDrawable="@drawable/custom_hp_bar" app:layout_constraintStart_toEndOf="@id/layoutAvatarClick" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/pbPlayerMP" />
                <ProgressBar android:id="@+id/pbPlayerMP" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_marginStart="6dp" android:progress="70" android:progressDrawable="@drawable/custom_progress_bar" app:layout_constraintStart_toEndOf="@id/layoutAvatarClick" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/pbPlayerHP" app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5.5" android:orientation="horizontal" android:weightSum="3" android:layout_marginHorizontal="4dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:orientation="vertical" android:gravity="center" android:layout_margin="1dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_resource_gold" />
                    <TextView android:id="@+id/tvTotalGold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:orientation="vertical" android:gravity="center" android:layout_margin="1dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_resource_iron" />
                    <TextView android:id="@+id/tvTotalIron" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:orientation="vertical" android:gravity="center" android:layout_margin="1dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_resource_wheat" />
                    <TextView android:id="@+id/tvTotalWheat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout 
                android:id="@+id/btnSettings"
                android:layout_width="0dp" 
                android:layout_height="match_parent" 
                android:layout_weight="1.5" 
                android:orientation="vertical" 
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_settings_gear" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الإعدادات" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
            </LinearLayout>
            
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutPlayerLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/bg_level_tag"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topHudContainer">
        <TextView android:id="@+id/tvPlayerLevel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lv. 1" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutTotalPower"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_level_tag"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/layoutPlayerLevel"
        app:layout_constraintBottom_toBottomOf="@id/layoutPlayerLevel">
        <TextView android:id="@+id/tvMainTotalPower" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚔️ قوة الفيلق: 0" android:textColor="#F4D03F" android:textSize="13sp" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSeasonInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTotalPower"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ساحة الغزوات الملحمية"
            android:textColor="#F4D03F"
            android:textSize="22sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"/>
            
        <TextView
            android:id="@+id/tvSeasonTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ينتهي الموسم خلال: 00:00:00"
            android:textColor="#BDC3C7"
            android:textSize="14sp"
            android:layout_marginTop="5dp"/>
            
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_inner_frame"
            android:paddingHorizontal="15dp"
            android:paddingVertical="8dp"
            android:layout_marginTop="10dp">
            
            <TextView
                android:id="@+id/tvArenaRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المركز: --"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginEnd="15dp"/>
                
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#555555"/>
            
            <TextView
                android:id="@+id/tvArenaScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="النقاط: 0"
                android:textColor="#2ECC71"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="15dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutArenaButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/layoutSeasonInfo"
        app:layout_constraintBottom_toTopOf="@id/layoutAttackSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnLeaderboard"
            android:layout_width="140dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_btn_gold_border"
            android:text="قائمة المتصدرين"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="10dp"/>

        <Button
            android:id="@+id/btnArenaRewards"
            android:layout_width="140dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_inner_frame"
            android:text="جوائز الموسم"
            android:textColor="#F4D03F"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutAttackSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvArenaStamina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="طاقة الهجوم: 5/5"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>
            
        <TextView
            android:id="@+id/tvStaminaRegen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تتجدد المحاولة القادمة خلال: 00:00"
            android:textColor="#BDC3C7"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnAttack"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_btn_gold_border"
            android:text="ابحث عن خصم ⚔️"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
            
        <Button
            android:id="@+id/btnAddStamina"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:background="#00000000"
            android:text="شحن الطاقة (إعلان 🎥)"
            android:textColor="#3498DB"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="5dp"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="H,5.4:1"
        android:layout_marginHorizontal="2dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/bg_top_hud_blank" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <LinearLayout android:id="@+id/btnNavHeroes" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:layout_margin="2dp" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu_heroes" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الأبطال" android:textColor="#B3B3B3" android:textSize="8sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:id="@+id/btnNavQuests" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:layout_margin="2dp" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu_quests" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المهام" android:textColor="#B3B3B3" android:textSize="8sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:id="@+id/btnNavCity" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:layout_margin="2dp" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="25dp" android:layout_height="25dp" android:src="@android:drawable/ic_menu_mapmode" app:tint="#B3B3B3" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المدينة" android:textColor="#B3B3B3" android:textSize="9sp" android:textStyle="bold" />
            </LinearLayout>
            
            <LinearLayout android:id="@+id/btnNavArena" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:layout_margin="2dp" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="22dp" android:layout_height="22dp" android:text="⚔️" android:textSize="18sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الساحة" android:textColor="@color/royal_gold_light" android:textSize="9sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:id="@+id/btnNavBag" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:layout_margin="2dp" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu_bag" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الحقيبة" android:textColor="#B3B3B3" android:textSize="8sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
