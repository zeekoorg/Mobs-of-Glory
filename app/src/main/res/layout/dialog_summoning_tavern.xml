<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingBottom="25dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="fitXY"
            android:src="@drawable/bg_dialog_dark"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="قاعة الأساطير"
            android:textColor="#F4D03F"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSummonMedals"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="دعوات ملكية: 0"
            android:textColor="#2ECC71"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvDialogTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnSummonPremium"
            android:layout_width="220dp"
            android:layout_height="50dp"
            android:layout_marginTop="25dp"
            android:background="@drawable/bg_btn_gold_border"
            android:text="استدعاء أسطوري"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_item_legend_medal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvSummonMedals"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnSummonAd"
            android:layout_width="220dp"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_btn_gold_border"
            android:text="استدعاء مجاني"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_ui_ad_video"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/btnSummonPremium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:layout_marginTop="25dp"
            android:background="@drawable/bg_btn_gold_border"
            android:text="مغادرة القاعة"
            android:textColor="#BDC3C7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="0dp"
            app:layout_constraintTop_toBottomOf="@id/btnSummonAd"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
