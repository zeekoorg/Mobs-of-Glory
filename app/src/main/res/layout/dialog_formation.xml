<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.95"
        app:layout_constraintHeight_percent="0.90"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/bg_dialog_dark" />

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:text="تجهيز الفيلق الملكي"
            android:textColor="#F4D03F"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutLegionPower"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_level_tag"
            android:paddingHorizontal="20dp"
            android:paddingVertical="5dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvDialogTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvFormationPower"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="قوة الفيلق: ⚔️ 0"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"
            app:layout_constraintTop_toBottomOf="@id/layoutLegionPower"
            app:layout_constraintBottom_toTopOf="@id/btnSaveFormation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أبطال الفيلق"
                    android:textColor="#F4D03F"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutSelectedHeroes"
                    android:layout_width="match_parent"
                    android:layout_height="85dp"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:layout_marginBottom="20dp">
                    
                    <FrameLayout android:id="@+id/slotHero1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_inner_frame" android:clickable="true" android:focusable="true">
                        <ImageView android:id="@+id/imgAddHero1" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add" app:tint="#F4D03F" />
                        <ImageView android:id="@+id/imgHero1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="5dp" android:visibility="gone" />
                    </FrameLayout>

                    <FrameLayout android:id="@+id/slotHero2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_inner_frame" android:clickable="true" android:focusable="true">
                        <ImageView android:id="@+id/imgAddHero2" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add" app:tint="#F4D03F" />
                        <ImageView android:id="@+id/imgHero2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="5dp" android:visibility="gone" />
                        <LinearLayout android:id="@+id/layoutLockHero2" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="#99000000">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_secure" app:tint="#FF5252"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قلعة 5" android:textColor="#FF5252" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout android:id="@+id/slotHero3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_inner_frame" android:clickable="true" android:focusable="true">
                        <ImageView android:id="@+id/imgAddHero3" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add" app:tint="#F4D03F" />
                        <ImageView android:id="@+id/imgHero3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="5dp" android:visibility="gone" />
                        <LinearLayout android:id="@+id/layoutLockHero3" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="#99000000">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_secure" app:tint="#FF5252"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قلعة 10" android:textColor="#FF5252" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout android:id="@+id/slotHero4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_inner_frame" android:clickable="true" android:focusable="true">
                        <ImageView android:id="@+id/imgAddHero4" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add" app:tint="#F4D03F" />
                        <ImageView android:id="@+id/imgHero4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="5dp" android:visibility="gone" />
                        <LinearLayout android:id="@+id/layoutLockHero4" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="#99000000">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_secure" app:tint="#FF5252"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قلعة 15" android:textColor="#FF5252" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ترسانة الفيلق (الأسلحة)"
                    android:textColor="#F4D03F"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutSelectedWeapons"
                    android:layout_width="match_parent"
                    android:layout_height="85dp"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:layout_marginBottom="15dp">
                    
                    <FrameLayout android:id="@+id/slotWeapon1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_inner_frame" android:clickable="true" android:focusable="true">
                        <ImageView android:id="@+id/imgAddWeapon1" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add" app:tint="#F4D03F" />
                        <ImageView android:id="@+id/imgWeapon1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="5dp" android:visibility="gone" />
                    </FrameLayout>

                    <FrameLayout android:id="@+id/slotWeapon2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_inner_frame" android:clickable="true" android:focusable="true">
                        <ImageView android:id="@+id/imgAddWeapon2" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add" app:tint="#F4D03F" />
                        <ImageView android:id="@+id/imgWeapon2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="5dp" android:visibility="gone" />
                        <LinearLayout android:id="@+id/layoutLockWeapon2" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="#99000000">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_secure" app:tint="#FF5252"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قلعة 5" android:textColor="#FF5252" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout android:id="@+id/slotWeapon3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_inner_frame" android:clickable="true" android:focusable="true">
                        <ImageView android:id="@+id/imgAddWeapon3" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add" app:tint="#F4D03F" />
                        <ImageView android:id="@+id/imgWeapon3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="5dp" android:visibility="gone" />
                        <LinearLayout android:id="@+id/layoutLockWeapon3" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="#99000000">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_secure" app:tint="#FF5252"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قلعة 10" android:textColor="#FF5252" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout android:id="@+id/slotWeapon4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_inner_frame" android:clickable="true" android:focusable="true">
                        <ImageView android:id="@+id/imgAddWeapon4" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add" app:tint="#F4D03F" />
                        <ImageView android:id="@+id/imgWeapon4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="5dp" android:visibility="gone" />
                        <LinearLayout android:id="@+id/layoutLockWeapon4" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="#99000000">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_secure" app:tint="#FF5252"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قلعة 15" android:textColor="#FF5252" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <Button
            android:id="@+id/btnSaveFormation"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_btn_gold_border"
            android:text="موافق"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/btnClose"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:layout_marginBottom="20dp"
            android:background="#00000000"
            android:text="إلغاء"
            android:textColor="#BDC3C7"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
