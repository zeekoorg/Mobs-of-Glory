<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <ImageView
        android:id="@+id/imgCityBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:id="@+id/topResourcesBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#99000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_resource_gold" />
            <TextView
                android:id="@+id/tvTotalGold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_resource_iron" />
            <TextView
                android:id="@+id/tvTotalIron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_resource_wheat" />
            <TextView
                android:id="@+id/tvTotalWheat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutPlayerLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/topResourcesBar"
        android:layout_alignParentStart="true"
        android:layout_alignParentLeft="true"
        android:layout_margin="8dp"
        android:background="#B3000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlayerLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lv. 1"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/pbPlayerMP"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="80dp"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:progressDrawable="@drawable/custom_progress_bar"
                android:max="100" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/btnNavStore"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_nav_store" />

    <FrameLayout android:id="@+id/plotCastle" android:layout_width="150dp" android:layout_height="150dp" android:layout_centerInParent="true" />
    <FrameLayout android:id="@+id/plotFarmR1" android:layout_width="110dp" android:layout_height="110dp" android:layout_above="@id/plotCastle" android:layout_toEndOf="@id/plotCastle" android:layout_marginStart="10dp" android:layout_marginBottom="10dp" />
    <FrameLayout android:id="@+id/plotFarmR2" android:layout_width="110dp" android:layout_height="110dp" android:layout_below="@id/plotCastle" android:layout_toEndOf="@id/plotCastle" android:layout_marginStart="10dp" android:layout_marginTop="10dp" />
    <FrameLayout android:id="@+id/plotHospitalM1" android:layout_width="110dp" android:layout_height="110dp" android:layout_above="@id/plotCastle" android:layout_toStartOf="@id/plotCastle" android:layout_marginEnd="10dp" android:layout_marginBottom="10dp" />
    <FrameLayout android:id="@+id/plotHospitalM2" android:layout_width="110dp" android:layout_height="110dp" android:layout_below="@id/plotCastle" android:layout_toStartOf="@id/plotCastle" android:layout_marginEnd="10dp" android:layout_marginTop="10dp" />
    <FrameLayout android:id="@+id/plotBarracksL1" android:layout_width="110dp" android:layout_height="110dp" android:layout_above="@id/plotHospitalM1" android:layout_alignStart="@id/plotHospitalM1" android:layout_marginBottom="10dp" />
    <FrameLayout android:id="@+id/plotBarracksL2" android:layout_width="110dp" android:layout_height="110dp" android:layout_below="@id/plotHospitalM2" android:layout_alignStart="@id/plotHospitalM2" android:layout_marginTop="10dp" />

</RelativeLayout>
