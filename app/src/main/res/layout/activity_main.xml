<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr"
    android:background="#121212">

    <ImageView
        android:id="@+id/imgCityBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_mobs_city_isometric" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mapContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        app:layout_constraintDimensionRatio="9:16"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout android:id="@+id/plotCastle" android:layout_width="0dp" android:layout_height="0dp" android:clipChildren="false" app:layout_constraintWidth_percent="0.52" app:layout_constraintHeight_percent="0.30" app:layout_constraintHorizontal_bias="0.55" app:layout_constraintVertical_bias="0.22" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        
        <ImageView
            android:id="@+id/imgFloatingCastleEvent"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/ic_floating_event"
            app:layout_constraintBottom_toTopOf="@id/plotCastle"
            app:layout_constraintStart_toStartOf="@id/plotCastle"
            app:layout_constraintEnd_toEndOf="@id/plotCastle"
            android:layout_marginBottom="-15dp"
            android:elevation="10dp"/>

        <FrameLayout android:id="@+id/plotFarmR1" android:layout_width="0dp" android:layout_height="0dp" android:clipChildren="false" app:layout_constraintWidth_percent="0.28" app:layout_constraintHeight_percent="0.16" app:layout_constraintHorizontal_bias="0.77" app:layout_constraintVertical_bias="0.54" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        <FrameLayout android:id="@+id/plotBarracksL1" android:layout_width="0dp" android:layout_height="0dp" android:clipChildren="false" app:layout_constraintWidth_percent="0.28" app:layout_constraintHeight_percent="0.16" app:layout_constraintHorizontal_bias="0.26" app:layout_constraintVertical_bias="0.54" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        <FrameLayout android:id="@+id/plotHospitalM1" android:layout_width="0dp" android:layout_height="0dp" android:clipChildren="false" app:layout_constraintWidth_percent="0.28" app:layout_constraintHeight_percent="0.16" app:layout_constraintHorizontal_bias="0.52" app:layout_constraintVertical_bias="0.65" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        <FrameLayout android:id="@+id/plotFarmR2" android:layout_width="0dp" android:layout_height="0dp" android:clipChildren="false" app:layout_constraintWidth_percent="0.28" app:layout_constraintHeight_percent="0.16" app:layout_constraintHorizontal_bias="0.77" app:layout_constraintVertical_bias="0.79" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        <FrameLayout android:id="@+id/plotBarracksL2" android:layout_width="0dp" android:layout_height="0dp" android:clipChildren="false" app:layout_constraintWidth_percent="0.28" app:layout_constraintHeight_percent="0.16" app:layout_constraintHorizontal_bias="0.26" app:layout_constraintVertical_bias="0.78" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        <FrameLayout android:id="@+id/plotHospitalM2" android:layout_width="0dp" android:layout_height="0dp" android:clipChildren="false" app:layout_constraintWidth_percent="0.28" app:layout_constraintHeight_percent="0.16" app:layout_constraintHorizontal_bias="0.51" app:layout_constraintVertical_bias="0.87" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topHudContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="H,5.4:1"
        android:layout_marginHorizontal="2dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/bg_top_hud_blank" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="10"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3">
                
                <FrameLayout
                    android:id="@+id/layoutAvatarClick"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="100dp"
                        app:cardElevation="0dp"
                        android:layout_margin="3dp">
                        <ImageView
                            android:id="@+id/imgMainPlayerAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_default_avatar" />
                    </androidx.cardview.widget.CardView>
                    
                    <ImageView 
                        android:id="@+id/imgAvatarFrame" 
                        android:layout_width="match_parent" 
                        android:layout_height="match_parent" 
                        android:src="@drawable/ic_user_frame" />
                </FrameLayout>
                
                <ProgressBar android:id="@+id/pbPlayerHP" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_marginStart="6dp" android:progress="100" android:progressDrawable="@drawable/custom_hp_bar" app:layout_constraintStart_toEndOf="@id/layoutAvatarClick" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/pbPlayerMP" />
                <ProgressBar android:id="@+id/pbPlayerMP" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_marginStart="6dp" android:progress="70" android:progressDrawable="@drawable/custom_progress_bar" app:layout_constraintStart_toEndOf="@id/layoutAvatarClick" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/pbPlayerHP" app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5.5" android:orientation="horizontal" android:weightSum="3" android:layout_marginHorizontal="4dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:orientation="vertical" android:gravity="center" android:layout_margin="1dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_resource_gold" />
                    <TextView android:id="@+id/tvTotalGold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:orientation="vertical" android:gravity="center" android:layout_margin="1dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_resource_iron" />
                    <TextView android:id="@+id/tvTotalIron" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:orientation="vertical" android:gravity="center" android:layout_margin="1dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_resource_wheat" />
                    <TextView android:id="@+id/tvTotalWheat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout 
                android:id="@+id/btnSettings"
                android:layout_width="0dp" 
                android:layout_height="match_parent" 
                android:layout_weight="1.5" 
                android:orientation="vertical" 
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_settings_gear" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الإعدادات" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
            </LinearLayout>
            
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutPlayerLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/bg_level_tag"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topHudContainer">
        
        <TextView 
            android:id="@+id/tvPlayerLevel" 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content" 
            android:text="Lv. 1" 
            android:textColor="#FFFFFF" 
            android:textSize="13sp" 
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutTotalPower"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_level_tag"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/layoutPlayerLevel"
        app:layout_constraintBottom_toBottomOf="@id/layoutPlayerLevel">

        <TextView
            android:id="@+id/tvMainTotalPower"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚔️ 0"
            android:textColor="#F4D03F"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutVipClick"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@id/layoutPlayerLevel"
        app:layout_constraintEnd_toEndOf="@id/layoutPlayerLevel"
        app:layout_constraintTop_toBottomOf="@id/layoutPlayerLevel"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/imgVipIcon"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_vip_crown" 
            android:background="@drawable/bg_btn_gold_border"
            android:padding="6dp"/>

        <TextView
            android:id="@+id/tvVipTimerUI"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIP غير مفعل"
            android:textColor="#FF5252"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_level_tag"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutCastleRewardsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@id/layoutVipClick"
        app:layout_constraintEnd_toEndOf="@id/layoutVipClick"
        app:layout_constraintTop_toBottomOf="@id/layoutVipClick"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/layoutCastleRewardsClick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="4dp"
                android:src="@drawable/ic_ui_castle_rewards" 
                android:background="@drawable/bg_btn_gold_border"
                android:padding="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/badgeCastleRewards"
                android:layout_width="12dp"
                android:layout_height="12dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="#00FF00"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:visibility="gone"
                app:cardElevation="2dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مكافآت القلعة"
            android:textColor="#F4D03F"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_level_tag"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutWeeklyQuestsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@id/layoutCastleRewardsContainer"
        app:layout_constraintEnd_toEndOf="@id/layoutCastleRewardsContainer"
        app:layout_constraintTop_toBottomOf="@id/layoutCastleRewardsContainer"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/layoutWeeklyQuestsClick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="4dp"
                android:src="@drawable/ic_menu_quests" 
                android:background="@drawable/bg_btn_gold_border"
                android:padding="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/badgeWeeklyQuests"
                android:layout_width="12dp"
                android:layout_height="12dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="#00FF00"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:visibility="gone"
                app:cardElevation="2dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_level_tag"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المهام الأسبوعية"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvWeeklyTimerUI"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="#F4D03F"
                android:textSize="9sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/btnNavArena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@id/layoutWeeklyQuestsContainer"
        app:layout_constraintEnd_toEndOf="@id/layoutWeeklyQuestsContainer"
        app:layout_constraintTop_toBottomOf="@id/layoutWeeklyQuestsContainer"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_ui_arena" 
            android:background="@drawable/bg_btn_gold_border"
            android:padding="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ساحة الغزوات"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_level_tag"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTavernContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topHudContainer"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/layoutTavernClick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="4dp"
                android:src="@drawable/ic_ui_tavern" 
                android:background="@drawable/bg_btn_gold_border"
                android:padding="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/badgeTavern"
                android:layout_width="12dp"
                android:layout_height="12dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="#00FF00"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="-4dp"
                android:layout_marginStart="-4dp"
                android:visibility="gone"
                app:cardElevation="2dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="قاعة الأساطير"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_level_tag"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutWeaponsClick"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@id/layoutTavernContainer"
        app:layout_constraintEnd_toEndOf="@id/layoutTavernContainer"
        app:layout_constraintTop_toBottomOf="@id/layoutTavernContainer"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_ui_weapons" 
            android:background="@drawable/bg_btn_gold_border"
            android:padding="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الأسلحة"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_level_tag"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutFormationClick"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@id/layoutWeaponsClick"
        app:layout_constraintEnd_toEndOf="@id/layoutWeaponsClick"
        app:layout_constraintTop_toBottomOf="@id/layoutWeaponsClick"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_ui_formation" 
            android:background="@drawable/bg_btn_gold_border"
            android:padding="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الفيلق"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_level_tag"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="H,5.4:1"
        android:layout_marginHorizontal="2dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/bg_top_hud_blank" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:clipChildren="false">

            <LinearLayout android:id="@+id/btnNavHeroes" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:layout_margin="2dp" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu_heroes" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الأبطال" android:textColor="#B3B3B3" android:textSize="8sp" android:textStyle="bold" />
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:clipChildren="false">
                <LinearLayout android:id="@+id/btnNavQuests" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_inner_frame" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu_quests" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المهام" android:textColor="#B3B3B3" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>
                <androidx.cardview.widget.CardView android:id="@+id/badgeQuests" android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#00FF00" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="-2dp" android:layout_marginEnd="-2dp" android:visibility="gone" app:cardElevation="2dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout android:id="@+id/btnNavCity" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_inner_frame" android:layout_margin="2dp" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="25dp" android:layout_height="25dp" android:src="@android:drawable/ic_menu_mapmode" app:tint="@color/royal_gold_light" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المدينة" android:textColor="@color/royal_gold_light" android:textSize="9sp" android:textStyle="bold" />
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:clipChildren="false">
                <LinearLayout android:id="@+id/btnNavStore" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_inner_frame" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu_store" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المتجر" android:textColor="#B3B3B3" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>
                <androidx.cardview.widget.CardView android:id="@+id/badgeStore" android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#00FF00" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="-2dp" android:layout_marginEnd="-2dp" android:visibility="visible" app:cardElevation="2dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:clipChildren="false">
                <LinearLayout android:id="@+id/btnNavBag" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_inner_frame" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu_bag" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الحقيبة" android:textColor="#B3B3B3" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>
                <androidx.cardview.widget.CardView android:id="@+id/badgeBag" android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#00FF00" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="-2dp" android:layout_marginEnd="-2dp" android:visibility="gone" app:cardElevation="2dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTutorialOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:elevation="100dp">

        <ImageView
            android:id="@+id/imgTutorialGuide"
            android:layout_width="150dp"
            android:layout_height="250dp"
            android:src="@drawable/img_guide_character"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="20dp"
            android:layout_marginStart="10dp"/>

        <TextView
            android:id="@+id/tvTutorialText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_gold_border"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="15dp"
            android:text="أهلاً بك يا سيدي المهيب، إمبراطوريتك بحاجة للغذاء، اضغط هنا لبناء المزرعة!"
            app:layout_constraintBottom_toBottomOf="@id/imgTutorialGuide"
            app:layout_constraintStart_toEndOf="@id/imgTutorialGuide"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="50dp"
            android:layout_marginStart="10dp"/>

        <ImageView
            android:id="@+id/imgTutorialPointer"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_pointer_hand"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="100dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
